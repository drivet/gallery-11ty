{% if navigation %}
  <nav class="album-nav">
    <span class="icon-folder"></span> 
    <ul class="breadcrumbs">
      <li class="breadcrumbs__item">
        <a href="/">All Albums</a>
      </li>
      {% if eleventyNavigation.parent %}
        {% set navPages = collections.albums |
     eleventyNavigationBreadcrumb(eleventyNavigation.parent, {includeSelf: true}) %}
      {% endif %}
      {%- for entry in navPages %}
        <li class="breadcrumbs__item">
          <a href="{{ entry.url }}">{{ entry.title }}</a>
        </li>
      {%- endfor -%}
    </ul>
  </nav>
{% endif %}
