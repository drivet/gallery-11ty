---
permalink: "{{ key }}/index.html"
layout: layouts/base
navigation: true
---
<article class="entry">
  <header class="entry__header">
    <h1 class="entry__title">{{title}}</h1>
    <div class=""entry__date>
      <span class="icon-calendar"></span> <span class="entry__published dt-published">{{ date | date  }}</span>
    </div>
    {% include "partials/navalbum.njk" %}
    <div class="entry__summary">
      {{ key | childSummary(collections.entryInfoByKey) }}
    </div>
  </header>
  {{ content | safe }}
  
  {% set navPages = key | albumChildren(collections.entryInfoByKey) %}
 
  {% if navPages[0].data.image %}
    <ul class="gallery-list">
      {% asyncEach a in navPages %}      
      <li class="gallery-list__item">
        <a href="{{a.url}}">
          {% smallImage a.data.image, "", "gallery-list__image" %}
        </a>
      </li>
       {% endeach %}
    </ul>
    
  {% else %}
    <ul class="album-list">
      {% asyncEach a in navPages | sort(true, false, 'date') %}      
      <li class="album-list__album-item">
        {% set url = a.url %}
        {% set title = a.data.title %}
        {% set featured = a.data.featured %}
        {% set date = a.data.date %}
        {% set key = a.data.key %}
        {% include "partials/album.njk" %}
      </li>
      {% endeach %}
    </ul>
    
  {% endif %}
<article>
