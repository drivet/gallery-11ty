{
  "name": "eleventy-albums",
  "version": "1.0.0",
  "description": "Eleventy based website for my photo albums",
  "main": "index.js",
  "scripts": {
    "start": "npm run dev",
    "dev": "ELEVENTY_ENV=development eleventy --serve",
    "devp": "ELEVENTY_ENV=development DEBUG=Eleventy:Benchmark* eleventy --serve",
    "devd": "ELEVENTY_ENV=development DEBUG=Eleventy:* eleventy --serve",
    "build": "ELEVENTY_ENV=production eleventy"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-navigation": "^1.0.5",
    "@11ty/eleventy-plugin-rss": "^3.0.0",
    "dayjs": "^1.11.20",
    "debug": "^4.4.3",
    "eleventy-plugin-metagen": "^1.8.3",
    "exifr": "^7.1.3",
    "lodash": "^4.17.23",
    "lucide-static": "^1.7.0",
    "sharp": "^0.34.5"
  },
  "type": "module"
}
